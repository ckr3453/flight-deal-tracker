DATABASE_URL=          # Turso: libsql://xxx.turso.io / 로컬: file:./prisma/dev.db
TURSO_AUTH_TOKEN=      # Turso 인증 토큰 (프로덕션만)
SERPAPI_API_KEY=       # SerpApi API 키 (Google Flights) - https://serpapi.com
RESEND_API_KEY=        # Resend 이메일 API 키 - https://resend.com
CRON_SECRET=           # Cron 엔드포인트 인증용 시크릿 (임의 문자열)
NEXTAUTH_SECRET=       # NextAuth 세션 암호화 시크릿 (임의 문자열)
AUTH_GOOGLE_ID=        # Google OAuth Client ID - https://console.cloud.google.com
AUTH_GOOGLE_SECRET=    # Google OAuth Client Secret
