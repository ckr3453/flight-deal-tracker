generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = []
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user") // "admin" | "user"
  isApproved    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  monitors Monitor[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Monitor {
  id           String   @id @default(cuid())
  userId       String
  flyFrom      String   // 출발 공항 IATA (예: ICN)
  flyTo        String   // 도착 공항/도시 IATA (예: NRT)
  flightType   String   @default("round") // "round" | "oneway"
  adults       Int      @default(1)
  children     Int      @default(0)
  infants      Int      @default(0)
  nightsFrom   Int?     // 최소 숙박일 (왕복만)
  nightsTo     Int?     // 최대 숙박일 (왕복만)
  dateFrom     String?  // 검색 시작일 (DD/MM/YYYY)
  dateTo       String?  // 검색 종료일 (DD/MM/YYYY)
  maxPrice     Int?     // 희망 최대 가격 (KRW)
  status       String   @default("active") // "active" | "paused"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  priceRecords  PriceRecord[]
  deals         Deal[]
  notifications Notification[]
}

model PriceRecord {
  id        String   @id @default(cuid())
  monitorId String
  minPrice  Int      // 최저가 (KRW)
  avgPrice  Int      // 평균가 (KRW)
  maxPrice  Int      // 최고가 (KRW)
  count     Int      // 검색된 항공편 수
  checkedAt DateTime @default(now())

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
}

model Deal {
  id         String   @id @default(cuid())
  monitorId  String
  price      Int      // 감지된 가격 (KRW)
  dropRate   Float?   // 하락률 (%)
  dealType   String   // "price_drop" | "under_target" | "all_time_low"
  airline    String?  // 항공사
  bookingUrl String?  // 예약 링크
  detectedAt DateTime @default(now())

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  monitorId String
  dealType  String   // "price_drop" | "under_target" | "all_time_low"
  sentAt    DateTime @default(now())

  monitor Monitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
}
